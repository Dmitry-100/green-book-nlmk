# Database
POSTGRES_USER=greenbook
POSTGRES_PASSWORD=greenbook_dev
POSTGRES_DB=greenbook
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://greenbook:greenbook_dev@db:5432/greenbook
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_ENABLED=true
REDIS_CACHE_NAMESPACE=v1

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=greenbook-media

# Auth (dev mode — mock JWT)
AUTH_SECRET_KEY=dev-secret-key-change-in-production
AUTH_ALGORITHM=HS256

# App
APP_ENV=development
ENABLE_DEV_AUTH=true
CORS_ORIGINS=http://localhost:5173
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
API_GZIP_ENABLED=true
API_GZIP_MINIMUM_SIZE=1024
DASHBOARD_SUMMARY_CACHE_TTL_SECONDS=20
MAP_ZONES_CACHE_TTL_SECONDS=300
MAP_OBSERVATIONS_CACHE_TTL_SECONDS=10
GAMIFICATION_STATS_CACHE_TTL_SECONDS=30
SPECIES_LIST_CACHE_TTL_SECONDS=120
VALIDATION_QUEUE_CACHE_TTL_SECONDS=15
NOTIFICATION_UNREAD_CACHE_TTL_SECONDS=10
AUDIT_LOG_RETENTION_DAYS=180
OPS_ALERT_ON_REVIEW_THRESHOLD=100
OPS_ALERT_OPEN_INCIDENTS_THRESHOLD=0
OPS_ALERT_ERROR_RATE_PERCENT_THRESHOLD=5.0
OPS_ALERT_MEDIA_PENDING_THRESHOLD=200
OPS_ALERT_MEDIA_PENDING_AGE_SECONDS_THRESHOLD=900
OPS_ALERT_MEDIA_FAILED_THRESHOLD=0
OPS_ALERT_CACHE_DEGRADED_STORES_THRESHOLD=0
HEALTH_DEPENDENCY_TIMEOUT_MS=250
YMAPS_CONFIG_CACHE_TTL_SECONDS=3600
UVICORN_WORKERS=2
MEDIA_MAX_UPLOAD_BYTES=10485760
MEDIA_MAX_IMAGE_DIMENSION=2560
MEDIA_MAX_IMAGE_PIXELS=24000000
MEDIA_THUMBNAIL_SIZE=400
MEDIA_ASYNC_PROCESSING_ENABLED=true
MEDIA_PROCESSING_BATCH_SIZE=20
MEDIA_PROCESSING_MAX_ATTEMPTS=3
MEDIA_PROCESSING_RETRY_BACKOFF_SECONDS=30
MEDIA_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Yandex Maps
YMAPS_API_KEY=your-ymaps-api-key-here
